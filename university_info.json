  "admissions": {
    "undergraduate": {
      "eligibility": "Pass in Class 10+2 (Higher Secondary) with a minimum of 45% aggregate marks (40% for reserved categories). Specific entrance exams required: B.Tech (JEE Main/GUJCET), B.Arch (NATA/JEE), B.Des (PU-DAT).",
      "deadline": "July 31, 2026",
      "requirements": [
        "Online registration on admission portal",
        "Class 10 and 12 mark sheets and certificates",
        "National/State entrance scorecard (JEE/GUJCET/NATA)",
        "Transfer Certificate (TC) & Migration Certificate",
        "Valid Government ID (Aadhar Card)",
        "Passport-size photographs"
      ],
      "process": "1. Register on the Parul University admissions portal. 2. Fill in personal, contact, and academic details. 3. Upload scanned copies of required mark sheets and IDs. 4. Pay the application fee (INR 2,000) online. 5. Document verification by admissions office. 6. Receive provisional admission letter and pay tuition fees."
    },
    "postgraduate": {
      "eligibility": "Bachelor's degree in a relevant discipline from a recognized university with at least 50% aggregate marks (45% for reserved categories).",
      "deadline": "August 15, 2026",
      "requirements": [
        "Online admission application form",
        "Class 10, 12, and Graduation degree certificates/mark sheets",
        "Postgraduate entrance scorecard (CAT/MAT/CMAT/PGCET if applicable)",
        "Updated Resume/CV",
        "Migration and Transfer Certificates"
      ],
      "process": "1. Submit application online at the official portal. 2. Provide undergraduate academic credentials and entrance exam scores. 3. Participate in counseling/personal interview rounds (for MBA and specialized PG programs). 4. Upon selection, pay course fees to secure admission."
    },
    "scholarships": {
      "merit_based": "Up to 50% tuition waiver for outstanding academic achievements in board examinations or national level entrance tests.",
      "need_based": "Financial assistance, sports quota exemptions, and sibling/defense personal fee waivers available upon application verification.",
      "deadline": "June 30, 2026"
    }
  },
