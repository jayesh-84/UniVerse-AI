# ==============================================================================
# UniVerse AI Student Helpdesk Portal - Environment Variables Configuration
# Copy this file to '.env' and populate with actual credentials in production.
# ==============================================================================

# Flask Core Config
FLASK_APP=app.py
FLASK_ENV=production
FLASK_DEBUG=0

# Security Secrets (Generate secure random values for production)
# You can generate a hex token in Python: import secrets; print(secrets.token_hex(32))
JWT_SECRET_KEY=your_super_secret_jwt_token_key_here
CSRF_SECRET_KEY=your_super_secret_csrf_token_key_here

# Database URL
# Default fallback is local SQLite: sqlite:///instance/universe.db
# For PostgreSQL: postgresql://username:password@localhost:5432/universe_db
DATABASE_URL=sqlite:///instance/universe.db

# Gemini AI Credentials
# Obtain a key from the Google AI Studio console: https://aistudio.google.com
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere
